                      value={`${wallet.score} / 100`}
                    />

                    <MetricTile
                      label="Declared %"
                      value={formatPercent(wallet.declaredPercent)}
                    />

                    <MetricTile
                      label="Live Share"
                      value={formatPercent(wallet.liveSharePercent)}
                    />

                    <MetricTile
                      label="Variance %"
                      value={formatPercent(wallet.variancePercent, 3)}
